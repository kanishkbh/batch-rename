{
  "name": "batch-rename-extension",
  "displayName": "Batch Rename",
  "description": "Batch rename files in the explorer inside a text editor",
  "version": "0.0.7",
  "publisher": "JannisX11",
  "repository": {
    "type": "git",
    "url": "https://github.com/JannisX11/batch-rename"
  },
  "engines": {
    "vscode": "^1.89.1"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "extension.renameBatch",
        "title": "Batch Rename...",
        "category": "Batch Renamer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.renameBatch",
          "group": "7_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.89.1",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "license": "MIT",
  "keywords": [
    "rename",
    "multiple",
    "extension",
    "vscode"
  ]
}